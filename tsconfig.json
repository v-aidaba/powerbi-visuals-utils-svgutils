{
    "compilerOptions": {
        "allowJs": false,
        "declaration": true,
        "sourceMap": true,
        "module": "ES2020",
        "moduleResolution": "bundler",
        "target": "ES2020",
        "strict": true,
        "skipLibCheck": true,
        "lib": [
            "es2020",
            "dom"
        ],
        "rootDir": "./src",
        "outDir": "./lib"
    },
    "include": [
        "src/**/*.ts"
    ]
}